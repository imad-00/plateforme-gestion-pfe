# Core Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database
POSTGRES_DB=pfe_db
POSTGRES_USER=pfe
POSTGRES_PASSWORD=pfe
DATABASE_URL=postgresql://pfe:pfe@db:5432/pfe_db

# Cache / async
REDIS_URL=redis://redis:6379/0

# JWT and API pagination
SIMPLE_JWT_ACCESS_MINUTES=15
SIMPLE_JWT_REFRESH_DAYS=7
PASSWORD_RESET_OTP_TTL_MINUTES=10
API_PAGE_SIZE=10
API_MAX_PAGE_SIZE=100

# SMTP email (OTP sending)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=imadbnhl11@gmail.com
EMAIL_HOST_PASSWORD=ynnafwzqbwtyazppi
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=imadbnhl11@gmail.com
# Set to 1 in local dev to force the console backend (no real sends). Leave
# blank/0 to use EMAIL_BACKEND above. The dev settings module honors this flag.
EMAIL_FORCE_CONSOLE=0

# S3/MinIO storage
USE_S3=1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
# Public endpoint the browser will use for file downloads. Leave blank to fall
# back to MINIO_ENDPOINT (only works when MinIO is reachable under the same
# hostname from both Django and the browser). Typical local dev value:
# localhost:9000.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pfe-media
MINIO_REGION=us-east-1
MINIO_USE_SSL=0

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
